LIB CONNECT TO 'Moodle (corporativo)';

[E_Usuarios]:

LOAD "id",
    "auth",
    "confirmed",
    "policyagreed",
    "deleted",
    "suspended",
    "mnethostid",
    "username",
    "password",
    "idnumber",
    "firstname",
    "lastname",
    "email",
    "emailstop",
    "phone1",
    "phone2",
    "institution",
    "department",
    "address",
    "city",
